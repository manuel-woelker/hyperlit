tools {
	node "24.13.0" {
		download {
			windows "https://nodejs.org/dist/v${version}/node-v${version}-win-x64.zip"
			linux "https://nodejs.org/dist/v${version}/node-v${version}-linux-x64.tar.gz"
		}
		commands {
			node "node"
			npm "npm"
			npm "npm"
			npx "npx"
		}
		env {
			PATH "../${dir:node}"
		}
	}
}